# PostHog configuration for example.rb
# Copy this file to .env and fill in your actual values

# Your PostHog project API key (found on the /setup page in PostHog)
POSTHOG_PROJECT_API_KEY=your_project_api_key_here

# Your secret key (required for local feature flag evaluation)
# Accepts either a Personal API Key (phx_...) or a Project Secret API Key (phs_...)
POSTHOG_SECRET_KEY=your_secret_key_here

# PostHog host URL 
# - For PostHog Cloud US: https://us.posthog.com
# - For PostHog Cloud EU: https://eu.posthog.com
# - For self-hosted: your custom URL (e.g., http://localhost:8010)
POSTHOG_HOST=https://us.posthog.com